# Model providers (not used by broker — kept for future client adapters)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Supermemory (broker reads SUPERMEMORY_API_KEY and SUPERMEMORY_BASE_URL)
SUPERMEMORY_API_KEY=
SUPERMEMORY_BASE_URL=
# SUPERMEMORY_CC_API_KEY is for the Claude Code plugin only, not the broker:
# SUPERMEMORY_CC_API_KEY=

# Broker core
BROKER_PROJECT_ID=sir
BROKER_USER_ID=default-user
BROKER_LOCAL_CACHE_PATH=./.broker/cache
BROKER_CONFIG_PATH=./broker/config.example.json
BROKER_CLIENT_ADAPTER=claude-code
BROKER_CANONICAL_MEMORY=supermemory

# Ruflo (broker reads RUFLO_DB_PATH)
RUFLO_DB_PATH=.swarm/memory.db
# The following are Ruflo's own env vars, not read by the broker:
# CLAUDE_FLOW_LOG_LEVEL=info
# CLAUDE_FLOW_TOOL_MODE=develop
# CLAUDE_FLOW_TOOL_GROUPS=implement,test,fix,memory
BROKER_BIND_HOST=127.0.0.1
BROKER_BIND_PORT=8081
# Optional: set to require Bearer auth on all endpoints except /health
BROKER_API_KEY=
# Rate limiting: max requests per IP per window (0 = disabled)
BROKER_RATE_LIMIT=60
BROKER_RATE_WINDOW=60
BROKER_PUBLIC_BASE_URL=
BROKER_REMOTE_MODE=false

# Claude Code optional adapter
CLAUDE_CODE_ENABLED=true