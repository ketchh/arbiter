# Model providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Supermemory
SUPERMEMORY_API_KEY=
SUPERMEMORY_CC_API_KEY=
SUPERMEMORY_DEBUG=false
SUPERMEMORY_BASE_URL=
SUPERMEMORY_API_URL=
SUPERMEMORY_AUTH_URL=

# Runtime selection
BROKER_CLIENT_ADAPTER=claude-code
BROKER_ORCHESTRATOR=ruflo
BROKER_CANONICAL_MEMORY=supermemory

# Ruflo
CLAUDE_FLOW_LOG_LEVEL=info
CLAUDE_FLOW_TOOL_MODE=develop
CLAUDE_FLOW_TOOL_GROUPS=implement,test,fix,memory
CLAUDE_FLOW_MEMORY_PATH=./.ruflo/data
RUFLO_DB_PATH=.swarm/memory.db

# Broker
BROKER_PROJECT_ID=sir
BROKER_USER_ID=default-user
BROKER_LOCAL_CACHE_PATH=./.broker/cache
BROKER_CONFIG_PATH=./broker/config.example.json
BROKER_BIND_HOST=127.0.0.1
BROKER_BIND_PORT=8081
BROKER_PUBLIC_BASE_URL=
BROKER_REMOTE_MODE=false

# Claude Code optional adapter
CLAUDE_CODE_ENABLED=true